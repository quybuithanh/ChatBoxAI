        "Rất vui được gặp bạn!"
      ]
    },
    {
      "tag": "goodbye",
      "patterns": ["tạm biệt", "bye", "hẹn gặp lại", "cảm ơn nhé"],
      "responses": ["Tạm biệt bạn, chúc bạn học tốt!", "Hẹn gặp lại nhé!"]
    },
    {
      "tag": "hours",
      "patterns": [
